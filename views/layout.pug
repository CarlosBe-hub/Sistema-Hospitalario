doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title Sistema Hospitalario

    // Bootstrap CSS
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    // Bootstrap Icons
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css")
    // DataTables Bootstrap 5 CSS
    link(rel="stylesheet", href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css")
    // Estilos personalizados
    link(rel="stylesheet", href="/css/layout.css")

    block styles

  body
    // Sidebar
    .sidebar
      .text-center.mb-4
        img(src="/img/iconhospital.jpg", alt="Logo", width="45", height="45", class="mb-2 rounded")
        h5.text-white Sistema Hospital San Carlos 
      
      nav.nav.flex-column
        // --- SECCIÓN INICIO ---
        a.nav-link.text-white(class=activePage == '/' ? 'fw-bold text-primary' : '', href='/')
          i.bi.bi-house-door.me-2
          | Inicio 

        small.text-muted.px-3.text-uppercase.fw-bold.mt-3.mb-1 Gestión Hospitalaria

        a.nav-link.text-white(class=activePage == '/pacientes' ? 'fw-bold text-primary' : '', href='/pacientes')
          i.bi.bi-people-fill.me-2
          | Pacientes 

        a.nav-link.text-white(class=activePage == '/admision' ? 'fw-bold text-primary' : '', href='/admision')
          i.bi.bi-journal-plus.me-2
          | Admisión 

        a.nav-link.text-white(class=activePage == '/internacion/nueva' ? 'fw-bold text-primary' : '', href='/internacion/nueva')
          i.bi.bi-plus-circle.me-2
          | Nueva Internación

        a.nav-link.text-white(class=activePage == '/internacion/listado' ? 'fw-bold text-primary' : '', href='/internacion/listado')
          i.bi.bi-table.me-2
          | Listado Internaciones

        a.nav-link(href="/habitaciones/mapa")
            i.bi.bi-grid-3x3-gap-fill.me-2
            | Gestion De Habitaciones

        // --- SECCIÓN MÓDULOS CLÍNICOS ---
        small.text-muted.px-3.text-uppercase.fw-bold.mt-4.mb-1 Módulos Clínicos

        a.nav-link.text-white(class=activePage == '/enfermeria' ? 'fw-bold text-primary' : '', href='/enfermeria')
          i.bi.bi-clipboard-pulse.me-2
          | Enfermería 

        a.nav-link.text-white(class=activePage == '/medico' ? 'fw-bold text-primary' : '', href='/medico')
          i.bi.bi-stethoscope.me-2
          | Evaluación Médica 

        a.nav-link.text-white(class=activePage == '/cuidados-enfermeria' ? 'fw-bold text-primary' : '', href='/cuidados-enfermeria')
          i.bi.bi-heart-pulse.me-2
          | Cuidados Enfermería 

        a.nav-link.text-white(class=activePage == '/medico/historial' ? 'fw-bold text-primary' : '', href='/medico/historial')
          i.bi.bi-clock-history.me-2
          | Historial Médico 

        // --- SECCIÓN EMERGENCIAS ---
        small.text-muted.px-3.text-uppercase.fw-bold.mt-4.mb-1 Alertas

        a.nav-link.text-danger.fw-bold(class=activePage == '/emergencia/crear' ? 'bg-danger text-white rounded mx-2 px-2' : '', href='/emergencia/crear')
          i.bi.bi-exclamation-triangle-fill.me-2
          | Crear Paciente NN

        small.text-muted.px-3.text-uppercase.fw-bold.mt-4.mb-1 Administración

        a.nav-link.text-white(class=activePage == '/medico/GestionMedico' ? 'fw-bold text-primary' : '', href='/medico/GestionMedico')
          i.bi.bi-person-vcard.me-2
          | Gestionar Médicos

        a.nav-link.text-white(class=activePage == '/enfermero/GestionEnfermero' ? 'fw-bold text-primary' : '', href='/enfermeria/gestionEnfermero')
          i.bi.bi-person-badge.me-2
          | Gestionar Enfermeros 

    // Contenido principal
    .content
      block content

  // Scripts Base
  script(src="https://code.jquery.com/jquery-3.6.0.min.js")
  script(src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js")
  script(src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js")
  script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")

  block scripts