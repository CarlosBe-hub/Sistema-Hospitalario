extends ../layout

block content
  .container.mt-4
    h2.mb-4 
      i.bi.bi-heart-pulse.me-2.text-danger
      | Panel Médico - Pacientes Actualmente Internados

    table#tablaMedico.table.table-hover.table-bordered.shadow-sm
      thead.table-light
        tr
          th Paciente
          th DNI
          th Habitación
          th Cama
          th Fecha de Ingreso
          th Acciones
      tbody
        each internacion in pacientes
          tr
            td.fw-bold #{internacion.Paciente.nombre} #{internacion.Paciente.apellido}
            td #{internacion.Paciente.dni}
            td 
              span.badge.bg-secondary #{internacion.Cama && internacion.Cama.Habitacion ? 'Hab. ' + internacion.Cama.Habitacion.numero : 'N/D'}
            td #{internacion.Cama ? 'Cama ' + internacion.Cama.numero : 'N/D'}
            td
              - var fecha = new Date(internacion.fecha_ingreso);
              - var dia = String(fecha.getDate()).padStart(2, '0');
              - var mes = String(fecha.getMonth() + 1).padStart(2, '0');
              - var anio = fecha.getFullYear();
              | #{dia}/#{mes}/#{anio}
            td
              a.btn.btn-sm.btn-danger(href=`/medico/${internacion.id_internacion}`)
                i.bi.bi-stethoscope.me-1
                | Evolución / Clínica

block scripts
  script.
    $(document).ready(function() {
      $('#tablaMedico').DataTable({
        language: {
          url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
        },
        responsive: true
      });
    });