doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Login - Sistema Hospitalario
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css")
    style.
      body {
        background: linear-gradient(135deg, #74b9ff 0%, #0984e3 100%);
        height: 100vh;
      }
      .card-login {
        width: 100%;
        max-width: 420px;
        border-radius: 16px;
      }
  body.d-flex.align-items-center.justify-content-center
    
    .card.card-login.shadow-lg.border-0.bg-white
      .card-body.p-5
        
        .text-center.mb-4
          .bg-primary.bg-opacity-10.d-inline-block.p-3.rounded-circle.mb-3
            i.bi.bi-hospital.text-primary.fs-1
          h3.fw-bold.text-dark.mb-1 Gestión Hospitalaria
          p.text-muted.small Acceda a su panel operativo de internación

        if error
          .alert.alert-danger.d-flex.align-items-center.py-2.small.mb-4(role="alert")
            i.bi.bi-exclamation-triangle-fill.me-2.fs-5
            div #{error}

        form(action="/login", method="POST")
          
          .form-floating.mb-3
            input#email.form-control(type="email", name="email", placeholder="nombre@hospital.com", required)
            label(for="email")
              i.bi.bi-envelope.me-2.text-muted
              | Correo Electrónico
          
          .form-floating.mb-4
            input#password.form-control(type="password", name="password", placeholder="Contraseña", required)
            label(for="password")
              i.bi.bi-lock.me-2.text-muted
              | Contraseña

          button.btn.btn-primary.w-100.py-2.fs-5.fw-bold.shadow-sm(type="submit", style="border-radius: 10px;") 
            i.bi.bi-box-arrow-in-right.me-2
            | Ingresar al Sistema

        .text-center.mt-4
          span.text-muted.text-uppercase.fw-bold(style="font-size: 0.7rem; letter-spacing: 1px;") 
            | ULP • Hospital San Carlos