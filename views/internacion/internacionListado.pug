extends ../layout

block content
  .toast-container.position-fixed.top-0.end-0.p-3(style="z-index: 1080;")
    #toastSuccess.toast.align-items-center.text-white.bg-success.border-0(role="alert", aria-live="assertive", aria-atomic="true")
      .d-flex
        .toast-body
          i.bi.bi-check-circle-fill.me-2
          span#toastSuccessTexto La internación hospitalaria del paciente fue registrada con éxito.
        button.btn.btn-close.btn-close-white.me-2.m-auto(type="button", data-bs-dismiss="toast", aria-label="Close")

    // Ventanita flotante roja para rechazos lógicos
    #toastError.toast.align-items-center.text-white.bg-danger.border-0(role="alert", aria-live="assertive", aria-atomic="true")
      .d-flex
        .toast-body
          i.bi.bi-exclamation-octagon-fill.me-2
          span#toastErrorTexto Ocurrió un error inesperado.
        button.btn.btn-close.btn-close-white.me-2.m-auto(type="button", data-bs-dismiss="toast", aria-label="Close")

  .container.mt-4
    // Mensaje para avisar de DNI duplicado en pacientes NN
    #alertaError.alert.alert-danger.alert-dismissible.fade.show.d-none(role="alert")
      i.bi.bi-exclamation-triangle-fill.me-2
      strong ¡Error!
      |  El DNI ingresado ya pertenece a otro paciente registrado en el sistema.
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

    .d-flex.justify-content-between.align-items-center.mb-4
      h2.mb-0 Listado de Internaciones
      
      .d-flex.align-items-center
        label.fw-bold.me-2.text-nowrap(for="filtroEstado") Filtrar vista:
        select#filtroEstado.form-select.border-primary.fw-bold(style="width: auto; cursor: pointer;")
          option(value="Activa" selected) 🏥 Solo Internados (Activas)
          option(value="") 📁 Historial Completo (Todas)
          option(value="Alta Firmada") ✔️ Solo Altas Firmadas
          option(value="Anulada") ✖️ Solo Anuladas

    table#tablaInternaciones.table.table-bordered.table-hover
      thead
        tr
          th Paciente
          th DNI
          th Sexo
          th Fecha y Hora de Ingreso
          th Motivo
          th Ala
          th Habitación
          th Cama
          th Estado Cama
          th Estado Internación
          th Género en la Cama
          th Acciones
      tbody
        each internacion in internaciones
          tr
            td
              if internacion.Paciente && internacion.Paciente.dni.startsWith('NN-')
                span.badge.bg-danger.me-2 ⚠️ Emergencia NN
              else
                | #{internacion.Paciente ? internacion.Paciente.nombre + ' ' + internacion.Paciente.apellido : 'N/D'}
                
            td= internacion.Paciente ? internacion.Paciente.dni : 'N/D'
            td= internacion.Paciente ? internacion.Paciente.genero : 'N/D'

            - var fecha = new Date(internacion.fecha_ingreso);
            - var fechaStr = !isNaN(fecha) ? fecha.toLocaleDateString('es-AR') : '-';
            - var horaStr = !isNaN(fecha) ? fecha.toLocaleTimeString('es-AR', {hour: '2-digit', minute:'2-digit', hour12: false}) : '';
            td= fechaStr + ' ' + horaStr

            - var motivoDesc = internacion.MotivoInternacion ? internacion.MotivoInternacion.descripcion : '-'
            td= motivoDesc

            - var ala = (internacion.Cama && internacion.Cama.Habitacion && internacion.Cama.Habitacion.Ala) ? internacion.Cama.Habitacion.Ala.nombre : 'N/D'
            td= ala

            - var habitacionNumero = (internacion.Cama && internacion.Cama.Habitacion) ? internacion.Cama.Habitacion.numero : 'N/D'
            td= habitacionNumero

            - var camaNumero = internacion.Cama ? internacion.Cama.numero : 'N/D'
            td= camaNumero

            td
              if internacion.Cama && internacion.Cama.estado === 'Ocupada'
                span.text-danger.fw-bold 🛏️ Ocupada
              else if internacion.Cama && (internacion.Cama.estado === 'Higienizada' || internacion.Cama.estado === 'Disponible')
                span.text-warning.fw-bold 🛏️ Higienizada / Disponible
              else if internacion.Cama && internacion.Cama.estado === 'para_limpieza'
                span.text-info.fw-bold 🧽 Para Limpieza
              else if internacion.Cama && internacion.Cama.estado === 'Libre'
                span.text-success.fw-bold 🛏️ Libre
              else
                span.text-muted 🛏️ N/D

            td
              if internacion.estado === 'Finalizada'
                span.badge.bg-success Alta Firmada
              else if internacion.estado === 'Anulada'
                span.badge.bg-secondary Anulada
              else
                span.badge.bg-primary Activa

            - var generoEnCama = internacion.Paciente ? internacion.Paciente.genero : 'N/D'
            td= generoEnCama

            td.text-center
              if internacion.Paciente && internacion.Paciente.dni.startsWith('NN-')
                button.btn.btn-sm.btn-warning.btn-identificar.me-1(
                  type="button"
                  data-bs-toggle="modal"
                  data-bs-target="#modalIdentificar"
                  data-id=internacion.Paciente.id_paciente
                  data-dni=internacion.Paciente.dni
                  title="Identificar Paciente NN"
                )
                  i.bi.bi-person-check-fill
              
              // Botón de Anulación 
              if internacion.estado === 'Activa'
                button.btn.btn-sm.btn-outline-danger(
                  type="button"
                  onclick=`anularInternacionDirecto(${internacion.id_internacion})`
                  title="Anular internación y liberar cama automáticamente"
                )
                  i.bi.bi-x-circle-fill.me-1
                  | Anular
              else if !internacion.Paciente || !internacion.Paciente.dni.startsWith('NN-')
                span.text-muted -

    // Modal Identificar Paciente NN
    #modalIdentificar.modal.fade(tabindex="-1" aria-labelledby="modalIdentificarLabel" aria-hidden="true")
      .modal-dialog.modal-md
        .modal-content
          .modal-header.bg-warning.text-dark
            h5#modalIdentificarLabel.modal-title
              i.bi.bi-person-check-fill.me-2
              | Identificar Paciente NN
            button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
          .modal-body
            p.text-muted Asigne la identidad real al registro temporal: 
              strong#textDniTemporal ...
            
            form#formIdentificar(method="POST")
              .row.mb-3
                .col-md-6
                  label.form-label.fw-bold Nombre Real
                  input.form-control(type="text" name="nombre" required minlength="2" pattern="[a-zA-ZáéíóúÁÉÍÓÚñÑ\\s]+" title="Solo se permiten letras y espacios")
                .col-md-6
                  label.form-label.fw-bold Apellido Real
                  input.form-control(type="text" name="apellido" required minlength="2" pattern="[a-zA-ZáéíóúÁÉÍÓÚñÑ\\s]+" title="Solo se permiten letras y espacios")
              .row.mb-3
                .col-md-6
                  label.form-label.fw-bold DNI Real
                  input.form-control(type="number" name="dni" required min="1000000" max="999999999" title="Debe ingresar un DNI válido sin puntos ni espacios")
                .col-md-6
                  label.form-label.fw-bold Género
                  select.form-select(name="genero" required)
                    option(value="" disabled selected) Seleccione...
                    option(value="Masculino") Masculino
                    option(value="Femenino") Femenino
                    option(value="Otro") Otro
              .row.mb-3
                .col-md-4
                  label.form-label.fw-bold Edad
                  input.form-control(type="number" name="edad" min="0" max="130")
                .col-md-8
                  label.form-label.fw-bold Obra Social
                  select.form-select(name="id_obra_social")
                    option(value="") Seleccione... / No Posee
                    if obrasSociales
                      each os in obrasSociales
                        option(value=os.id_obra_social)= os.nombre
              .mb-3
                label.form-label.fw-bold Teléfono
                input.form-control(type="text" name="telefono" pattern="[0-9]{7,15}" title="Ingrese un número de teléfono válido")
                
              .modal-footer.pe-0.pb-0
                button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
                button.btn.btn-warning.fw-bold(type="submit") Guardar Identidad

    hr
    h5.mt-4 Leyenda de Camas:
    p
      span.text-success.fw-bold 🛏️ Libre
      |  |  
      span.text-info.fw-bold 🧽 Para Limpieza
      |  |  
      span.text-danger.fw-bold 🛏️ Ocupada

  // CDN DataTables
  script(src="https://code.jquery.com/jquery-3.6.0.min.js")
  script(src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js")
  link(rel="stylesheet", href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css")

  script.
    $(document).ready(function() {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('error') === 'dni_duplicado') {
        $('#alertaError').removeClass('d-none');
        window.history.replaceState({}, document.title, window.location.pathname);
      }

      if (urlParams.get('success') === '1') {
        dispararToastSuccess('La internación hospitalaria fue registrada con éxito.');
        window.history.replaceState({}, document.title, window.location.pathname);
      }

      const tabla = $('#tablaInternaciones').DataTable({
        language: {
          url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
        },
        pageLength: 5,
        lengthMenu: [[5, 10, 25, -1], [5, 10, 25, "Todos"]],
        order: [[3, "desc"]]
      });

      tabla.column(9).search('Activa').draw();

      $('#filtroEstado').on('change', function() {
        tabla.column(9).search(this.value).draw();
      }); 

      $('#tablaInternaciones tbody').on('click', '.btn-identificar', function() {
        const idPaciente = $(this).attr('data-id');
        const dniTemporal = $(this).attr('data-dni');

        $('#textDniTemporal').text(dniTemporal);
        $('#formIdentificar').attr('action', '/pacientes/identificar/' + idPaciente);
      });
    });

    function anularInternacionDirecto(idInternacion) {
      $.ajax({
        url: `/internacion/${idInternacion}/anular`,
        method: 'PUT',
        success: function(res) {
          dispararToastSuccess(res.message || 'Internación anulada con éxito.');
          setTimeout(() => { location.reload(); }, 1500);
        },
        error: function(err) {
          const msg = err.responseJSON?.error || 'No se pudo procesar la anulación de la internación.';
          mostrarToastError(msg);
        }
      });
    }

    // Funciones auxiliares para Toasts flotantes
    function dispararToastSuccess(mensaje) {
      $('#toastSuccessTexto').text(mensaje);
      const toastElement = document.getElementById('toastSuccess');
      const bsToast = new bootstrap.Toast(toastElement, { delay: 4000 });
      bsToast.show();
    }

    function mostrarToastError(mensaje) {
      $('#toastErrorTexto').text(mensaje);
      const errorElement = document.getElementById('toastError');
      const bsToast = new bootstrap.Toast(errorElement, { delay: 4500 });
      bsToast.show();
    }