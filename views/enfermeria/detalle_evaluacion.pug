extends ../layout

block content
  .container.mt-4
    .d-flex.justify-content-between.align-items-center.mb-4
      h2 
        i.bi.bi-person-lines-fill.me-2
        | Evaluación de Enfermería
      a.btn.btn-outline-secondary(href="/enfermeria") Volver al listado

    // Tarjeta de Informacion del Paciente
    .card.mb-4.shadow-sm
      .card-body
        .row
          .col-md-3
            strong Paciente: 
            | #{internacion.Paciente.nombre} #{internacion.Paciente.apellido}
          .col-md-3
            strong DNI: 
            | #{internacion.Paciente.dni}
          .col-md-3
            strong Edad: 
            | #{internacion.Paciente.edad || 'N/D'} años
          .col-md-3
            strong Género: 
            | #{internacion.Paciente.genero}

    // Pestañas de Evaluación
    ul.nav.nav-tabs#evaluacionTabs(role="tablist")
      li.nav-item(role="presentation")
        button.nav-link.active#signos-tab(data-bs-toggle="tab", data-bs-target="#signos", type="button", role="tab") Signos Vitales
      li.nav-item(role="presentation")
        button.nav-link#historial-tab(data-bs-toggle="tab", data-bs-target="#historial", type="button", role="tab") Historial Médico Inicial
      li.nav-item(role="presentation")
        button.nav-link#cuidados-tab(data-bs-toggle="tab", data-bs-target="#cuidados", type="button", role="tab") Plan de Cuidados

    .tab-content.p-4.border.border-top-0.bg-white.shadow-sm#evaluacionTabsContent
      
      // SIGNOS VITALES 
      .tab-pane.fade.show.active#signos(role="tabpanel")
        if internacion.SignosVitales && internacion.SignosVitales.length > 0
          h5.text-success Signos Vitales Registrados
          - var ultimoControl = internacion.SignosVitales[0]
        else
          h5 Registrar Signos Vitales
          - var ultimoControl = {}

        form#formSignos
          input(type="hidden", name="id_internacion", value=internacion.id_internacion)
          input(type="hidden", name="id_paciente", value=internacion.id_paciente)
          input(type="hidden", name="id_enfermero", value="1") 
          
          .row.mb-3
            .col-md-3
              label.form-label Presión Arterial
              input.form-control(type="text", name="presion_arterial", placeholder="Ej: 120/80", value=ultimoControl.presion_arterial, required=!ultimoControl.id_signos, readonly=ultimoControl.id_signos)
            .col-md-3
              label.form-label Frecuencia Cardíaca
              input.form-control(type="number", name="frecuencia_cardiaca", placeholder="Latidos por min", value=ultimoControl.frecuencia_cardiaca, required=!ultimoControl.id_signos, readonly=ultimoControl.id_signos)
            .col-md-3
              label.form-label Frecuencia Respiratoria
              input.form-control(type="number", name="frecuencia_respiratoria", placeholder="Resp por min", value=ultimoControl.frecuencia_respiratoria, required=!ultimoControl.id_signos, readonly=ultimoControl.id_signos)
            .col-md-3
              label.form-label Temperatura (°C)
              input.form-control(type="number", step="0.1", name="temperatura", placeholder="Ej: 36.5", value=ultimoControl.temperatura, required=!ultimoControl.id_signos, readonly=ultimoControl.id_signos)
          
          .mb-3
            label.form-label Aspecto General
            input.form-control(type="text", name="aspecto_general", placeholder="Color de piel, nivel de consciencia, etc.", value=ultimoControl.aspecto_general, readonly=ultimoControl.id_signos)
          
          if !ultimoControl.id_signos
            button.btn.btn-primary(type="submit") Guardar Signos Vitales
          div#msgSignos.mt-2

      // HISTORIAL MEDICO
      .tab-pane.fade#historial(role="tabpanel")
        if internacion.HistorialMedicos && internacion.HistorialMedicos.length > 0
          h5.text-success Historial Clínico de Ingreso Registrado
          - var hClinico = internacion.HistorialMedicos[0]
        else
          h5 Historial Clínico de Ingreso
          - var hClinico = {}

        form#formHistorial
          input(type="hidden", name="id_internacion", value=internacion.id_internacion)
          input(type="hidden", name="id_paciente", value=internacion.id_paciente)
          input(type="hidden", name="id_enfermero", value="1")

          .row.mb-3
            .col-md-6
              label.form-label Motivo de Internación
              input.form-control(type="text", name="motivo_internacion", value=hClinico.motivo_internacion, required=!hClinico.id_historialmedico, readonly=hClinico.id_historialmedico)
            .col-md-6
              label.form-label Síntomas Principales
              input.form-control(type="text", name="sintomas_principales", value=hClinico.sintomas_principales, required=!hClinico.id_historialmedico, readonly=hClinico.id_historialmedico)

          .row.mb-3
            .col-md-6
              label.form-label Enfermedades Previas
              textarea.form-control(name="enfermedades_previas", rows="2", readonly=hClinico.id_historialmedico)= hClinico.enfermedades_previas
            .col-md-6
              label.form-label Medicamentos Actuales
              textarea.form-control(name="medicamentos_actuales", rows="2", readonly=hClinico.id_historialmedico)= hClinico.medicamentos_actuales

          .row.mb-3
            .col-md-4
              label.form-label Alergias
              input.form-control(type="text", name="alergias", value=hClinico.alergias, readonly=hClinico.id_historialmedico)
            .col-md-4
              label.form-label Cirugías
              input.form-control(type="text", name="cirugias", value=hClinico.cirugias, readonly=hClinico.id_historialmedico)
            .col-md-4
              label.form-label Antecedentes Familiares
              input.form-control(type="text", name="antecedentes_familiares", value=hClinico.antecedentes_familiares, readonly=hClinico.id_historialmedico)

          if !hClinico.id_historialmedico
            button.btn.btn-primary(type="submit") Guardar Historial Médico
          div#msgHistorial.mt-2

      // PLAN DE CUIDADOS 
      .tab-pane.fade#cuidados(role="tabpanel")
        if internacion.CuidadosEnfermerias && internacion.CuidadosEnfermerias.length > 0
          h5.text-success Plan Preliminar de Cuidados Registrado
          - var planCuid = internacion.CuidadosEnfermerias[0]
        else
          h5 Plan Preliminar de Cuidados
          - var planCuid = {}

        form#formCuidados
          input(type="hidden", name="id_internacion", value=internacion.id_internacion)
          input(type="hidden", name="id_paciente", value=internacion.id_paciente)
          input(type="hidden", name="id_enfermero", value="1")

          .mb-3
            label.form-label Plan de Cuidados Preliminar
            textarea.form-control(name="plan_cuidados", rows="3", required=!planCuid.id_cuidados, readonly=planCuid.id_cuidados)= planCuid.plan_cuidados
          
          .row.mb-3
            .col-md-6
              label.form-label Intervenciones Inmediatas
              textarea.form-control(name="intervenciones", rows="2", readonly=planCuid.id_cuidados)= planCuid.intervenciones
            .col-md-6
              label.form-label Medicamentos Administrados
              textarea.form-control(name="medicamentos_administrados", rows="2", readonly=planCuid.id_cuidados)= planCuid.medicamentos_administrados

          .mb-3
            label.form-label Observaciones
            textarea.form-control(name="observaciones", rows="2", readonly=planCuid.id_cuidados)= planCuid.observaciones

          if !planCuid.id_cuidados
            button.btn.btn-primary(type="submit") Guardar Plan de Cuidados
          div#msgCuidados.mt-2

block scripts
  script(src="https://code.jquery.com/jquery-3.6.0.min.js")
  script.
    $(document).ready(function() {
      // Manejo del envío asíncrono para Signos Vitales
      $('#formSignos').on('submit', function(e) {
        e.preventDefault();
        const form = $(this);
        $.ajax({
          url: 'signos-vitales',
          method: 'POST',
          data: form.serialize(),
          success: function(res) {
            $('#msgSignos').html('<div class="alert alert-success">' + (res.mensaje || 'Signos vitales registrados correctamente.') + '</div>');
            form.find('button[type="submit"]').remove();
            form.find('input').attr('readonly', true);
          },
          error: function(err) {
            $('#msgSignos').html('<div class="alert alert-danger">Error al guardar los signos vitales.</div>');
          }
        });
      });

      // Manejo del envío asíncrono para Historial Médico
      $('#formHistorial').on('submit', function(e) {
        e.preventDefault();
        const form = $(this);
        $.ajax({
          url: 'historial',
          method: 'POST',
          data: form.serialize(),
          success: function(res) {
            $('#msgHistorial').html('<div class="alert alert-success">' + (res.mensaje || 'Historial médico inicial registrado correctamente.') + '</div>');
            form.find('button[type="submit"]').remove();
            form.find('input, textarea').attr('readonly', true);
          },
          error: function(err) {
            $('#msgHistorial').html('<div class="alert alert-danger">Error al guardar el historial médico.</div>');
          }
        });
      });

      // Manejo del envío asíncrono para Plan de Cuidados
      $('#formCuidados').on('submit', function(e) {
        e.preventDefault();
        const form = $(this);
        $.ajax({
          url: 'plan-cuidados',
          method: 'POST',
          data: form.serialize(),
          success: function(res) {
            $('#msgCuidados').html('<div class="alert alert-success">' + (res.mensaje || 'Plan de cuidados registrado exitosamente.') + '</div>');
            form.find('button[type="submit"]').remove();
            form.find('textarea').attr('readonly', true);
          },
          error: function(err) {
            $('#msgCuidados').html('<div class="alert alert-danger">Error al guardar el plan de cuidados.</div>');
          }
        });
      });
    });