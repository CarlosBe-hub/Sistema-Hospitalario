extends ../layout

block content
  .toast-container.position-fixed.top-0.end-0.p-3(style="z-index: 1080;")
    #toastSuccess.toast.align-items-center.text-white.bg-success.border-0(role="alert", aria-live="assertive", aria-atomic="true")
      .d-flex
        .toast-body
          i.bi.bi-check-circle-fill.me-2
          span#toastMensajeTexto Operación realizada con éxito.
        button.btn.btn-close.btn-close-white.me-2.m-auto(type="button", data-bs-dismiss="toast", aria-label="Close")

    #toastError.toast.align-items-center.text-white.bg-danger.border-0(role="alert", aria-live="assertive", aria-atomic="true")
      .d-flex
        .toast-body
          i.bi.bi-exclamation-octagon-fill.me-2
          span#toastErrorTexto Ocurrió un error inesperado.
        button.btn.btn-close.btn-close-white.me-2.m-auto(type="button", data-bs-dismiss="toast", aria-label="Close")

  .container.mt-4
    h1 Admisiones

    button.btn.btn-primary.mb-3(data-bs-toggle="modal", data-bs-target="#modalAdmision") + Nueva Admisión

    table#tablaAdmisiones.table.table-hover
      thead
        tr
          th ID
          th Paciente
          th Fecha
          th Motivo de Admisión
          th Estado
          th Acciones
      tbody
        each admision in admisiones
          tr
            td= admision.id_admision
            td= admision.paciente.nombre + ' ' + admision.paciente.apellido
            td= admision.fecha_admision
            td= admision.motivo_admision ? admision.motivo_admision.descripcion : 'Sin motivo'
            td
              if admision.estado === 'activo'
                span.badge.bg-success activo
              else
                span.badge.bg-secondary cancelado
            td
              button.btn.btn-sm.btn-warning.me-2(
                type="button",
                data-bs-toggle="modal",
                data-bs-target="#modalEditarAdmision",
                data-id=admision.id_admision,
                data-paciente=admision.id_paciente,
                data-fecha=admision.fecha_admision,
                data-motivo=admision.id_motivo,
                data-estado=admision.estado
              ) Editar
              if admision.estado == 'activo'
                button.btn.btn-sm.btn-danger(
                  type="button",
                  onclick=`cancelarAdmisionDirecto(${admision.id_admision})`
                ) Cancelar

  // Modal Nueva Admisión
  .modal.fade#modalAdmision(tabindex="-1", aria-labelledby="modalAdmisionLabel", aria-hidden="true")
    .modal-dialog
      .modal-content
        .modal-header
          h5.modal-title#modalAdmisionLabel Registrar Nueva Admisión
          button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
        form#formNuevaAdmision
          .modal-body
            .mb-3
              label.form-label Paciente
              select.form-select#id_paciente(name="id_paciente", required)
                option(value="") Seleccione un paciente...
                each paciente in pacientes
                  option(value=paciente.id_paciente)= paciente.nombre + ' ' + paciente.apellido + ' (DNI: ' + paciente.dni + ')'
              small.text-danger#err_paciente
            .mb-3
              label.form-label Fecha de Admisión
              input.form-control#fecha_admision(type="date", name="fecha_admision", required)
              small.text-danger#err_fecha
            .mb-3
              label.form-label Motivo
              select.form-select#id_motivo(name="id_motivo", required)
                option(value="") Seleccione un motivo...
                each motivo in motivos
                  option(value=motivo.id_motivo)= motivo.descripcion
              small.text-danger#err_motivo
          .modal-footer
            button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Cerrar
            button.btn.btn-primary(type="submit") Guardar Admisión

  // Modal Editar Admisión
  .modal.fade#modalEditarAdmision(tabindex="-1", aria-labelledby="modalEditarAdmisionLabel", aria-hidden="true")
    .modal-dialog
      .modal-content
        .modal-header
          h5.modal-title#modalEditarAdmisionLabel Editar Admisión
          button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
        form#formEditarAdmision
          input(type="hidden")#edit_id_admision
          input(type="hidden")#edit_id_paciente
          .modal-body
            .mb-3
              label.form-label Fecha de Admisión
              input.form-control#edit_fecha_admision(type="date", name="fecha_admision", required)
              small.text-danger#err_edit_fecha
            .mb-3
              label.form-label Motivo
              select.form-select#edit_id_motivo(name="id_motivo", required)
                option(value="") Seleccione un motivo...
                each motivo in motivos
                  option(value=motivo.id_motivo)= motivo.descripcion
              small.text-danger#err_edit_tipo
            .mb-3
              label.form-label Estado
              select.form-select#edit_estado(name="estado", required)
                option(value="activo") activo
                option(value="cancelado") cancelado
              small.text-danger#err_edit_estado
          .modal-footer
            button.btn.btn-secondary(type="button", data-bs-dismiss="modal") Cerrar
            button.btn.btn-primary(type="submit") Actualizar Cambios

  script(src="https://code.jquery.com/jquery-3.6.0.min.js")
  script(src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js")
  link(rel="stylesheet", href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css")

  script.
    $(document).ready(function () {
      // 1. Inicializar DataTables con idioma español
      $('#tablaAdmisiones').DataTable({
        language: {
          url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json'
        },
        order: [[0, "desc"]]
      });

      function formatearFechaArgentina(fechaStr) {
        if (!fechaStr) return '';
        const fecha = new Date(fechaStr);
        if (isNaN(fecha.getTime())) return fechaStr; 

        return fecha.toLocaleString('es-AR', {
          day: '2-digit',
          month: '2-digit',
          year: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
          hour12: false
        });
      }

      $('#tablaAdmisiones tbody tr').each(function () {
        const $celdaFecha = $(this).find('td').eq(2); 
        const fechaTexto = $celdaFecha.text().trim();
        if (fechaTexto) {
          const fechaFormateada = formatearFechaArgentina(fechaTexto);
          $celdaFecha.text(fechaFormateada);
        }
      });

      // Rellenar campos en el modal de edición al abrirlo
      $('#modalEditarAdmision').on('show.bs.modal', function (event) {
        const button = $(event.relatedTarget);
        $('#edit_id_admision').val(button.data('id'));
        $('#edit_id_paciente').val(button.data('paciente'));
        $('#edit_fecha_admision').val(button.data('fecha'));
        $('#edit_id_motivo').val(button.data('motivo'));
        $('#edit_estado').val(button.data('estado'));
      });

      // Enviar formulario (POST)
      $('#formNuevaAdmision').submit(function (e) {
        e.preventDefault();
        $('#err_paciente, #err_fecha, #err_motivo').text('');

        const data = {
          id_paciente: $('#id_paciente').val(),
          fecha_admision: $('#fecha_admision').val(),
          id_motivo: $('#id_motivo').val()
        };

        let flagError = false;
        if (!data.id_paciente) { $('#err_paciente').text('Debe seleccionar un paciente.'); flagError = true; }
        if (!data.fecha_admision) { $('#err_fecha').text('Debe ingresar una fecha.'); flagError = true; }
        if (!data.id_motivo) { $('#err_motivo').text('Debe seleccionar el motivo.'); flagError = true; }
        if (flagError) return;

        $.ajax({
          url: '/admision/guardar', 
          method: 'POST',
          contentType: 'application/json',
          data: JSON.stringify(data),
          success: function (res) {
            $('#modalAdmision').modal('hide');
            dispararToast('Nueva admisión registrada con éxito.');
            setTimeout(() => { location.reload(); }, 1500);
          },
          error: function (err) {
            $('#modalAdmision').modal('hide');
            if (err.responseJSON && err.responseJSON.error) {
              mostrarErrorAlerta(err.responseJSON.error);
            } else {
              mostrarErrorAlerta('Error interno al registrar la admisión.');
            }
          }
        });
      });

      // Enviar formulario editado 
      $('#formEditarAdmision').submit(function (e) {
        e.preventDefault();
        $('#err_edit_fecha, #err_edit_tipo, #err_edit_estado').text('');

        const idAdmision = $('#edit_id_admision').val();
        const data = {
          fecha_admision: $('#edit_fecha_admision').val(),
          id_motivo: $('#edit_id_motivo').val(),
          estado: $('#edit_estado').val(),
          id_paciente: $('#edit_id_paciente').val()
        };

        let hayError = false;
        if (!data.fecha_admision) { $('#err_edit_fecha').text('Debe ingresar la fecha.'); hayError = true; }
        if (!data.id_motivo) { $('#err_edit_tipo').text('Debe seleccionar un motivo.'); hayError = true; }
        if (!data.estado) { $('#err_edit_estado').text('Debe seleccionar un estado.'); hayError = true; }
        if (hayError) return;

        $.ajax({
          url: `/admision/${idAdmision}`,
          method: 'PUT',
          contentType: 'application/json',
          data: JSON.stringify(data),
          success: function (res) {
            $('#modalEditarAdmision').modal('hide');
            dispararToast('Admisión actualizada correctamente.');
            setTimeout(() => { location.reload(); }, 1500);
          },
          error: function (err) {
            $('#modalEditarAdmision').modal('hide');
            if (err.responseJSON && err.responseJSON.error) {
              mostrarErrorAlerta(err.responseJSON.error);
            } else {
              mostrarErrorAlerta('Error al intentar modificar la admisión.');
            }
          }
        });
      });
    });

    // Función directa para el botón "Cancelar"
    function cancelarAdmisionDirecto(id) {
      $.ajax({
        url: `/admision/${id}/cancelar`,
        method: 'PUT', 
        success: function(res) {
          dispararToast('La admisión fue cancelada correctamente.');
          setTimeout(() => { location.reload(); }, 1500);
        },
        error: function(err) {
          if (err.responseJSON && err.responseJSON.error) {
            mostrarErrorAlerta(err.responseJSON.error);
          } else {
            mostrarErrorAlerta('No se pudo procesar la baja de la admisión.');
          }
        }
      });
    }

    function dispararToast(mensaje) {
      $('#toastMensajeTexto').text(mensaje);
      const toastElement = document.getElementById('toastSuccess');
      const bsToast = new bootstrap.Toast(toastElement, { delay: 4000 });
      bsToast.show();
    }

    function mostrarErrorAlerta(mensaje) {
      $('#toastErrorTexto').text(mensaje);
      const errorElement = document.getElementById('toastError');
      const bsToast = new bootstrap.Toast(errorElement, { delay: 4500 });
      bsToast.show();
    }