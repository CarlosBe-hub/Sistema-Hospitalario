extends ../layout

block content
  .container.mt-4
    .d-flex.justify-content-between.align-items-center.mb-4
      h2.mb-0
        i.bi.bi-grid-3x3-gap-fill.text-primary.me-2
        | Estado de Habitaciones y Camas
      
      // Leyenda visual
      .d-flex.gap-3.bg-white.p-2.rounded.shadow-sm.border
        .d-flex.align-items-center
          span.badge.bg-success.me-2 &nbsp;
          small.fw-bold Libre
        .d-flex.align-items-center
          span.badge.bg-danger.me-2 &nbsp;
          small.fw-bold Ocupada
        .d-flex.align-items-center
          span.badge.bg-warning.text-dark.me-2 &nbsp;
          small.fw-bold Para Limpieza

    .row
      each habitacion in habitaciones
        .col-md-6.col-lg-4.mb-4
          .card.shadow-sm.h-100.border-0.bg-light
            .card-header.bg-white.fw-bold.d-flex.justify-content-between.align-items-center.border-bottom-0.pt-3
              span.fs-5
                i.bi.bi-door-open.text-secondary.me-2
                | Hab. #{habitacion.numero}
              span.badge.bg-secondary #{habitacion.Ala ? habitacion.Ala.nombre : 'Sin Ala'}
            
            .card-body
              .row.g-3
                if habitacion.Camas && habitacion.Camas.length > 0
                  each cama in habitacion.Camas
                    .col-6
                      // Color de fondo segun el estado de la cama
                      - var bgClass = cama.estado === 'Libre' ? 'bg-success text-white' : (cama.estado === 'Ocupada' ? 'bg-danger text-white' : (cama.estado === 'para_limpieza' ? 'bg-warning text-dark' : 'bg-secondary text-white'))
                      
                      .card.text-center.border-0.shadow-sm(class=bgClass style="min-height: 110px;")
                        .card-body.p-2.d-flex.flex-column.justify-content-center.align-items-center
                          h6.mb-1.fw-bold
                            i.bi.bi-hospital-bed.me-1
                            | Cama #{cama.numero}
                          
                          small.mb-2 
                            if cama.estado === 'para_limpieza'
                              | Requiere Limpieza
                            else
                              | #{cama.estado}

                          // El boton manda el POST al controlador de habitaciones
                          if cama.estado === 'para_limpieza'
                            form(action=`/habitaciones/liberar/${cama.id_cama}` method="POST" class="mt-auto w-100")
                              button.btn.btn-sm.btn-light.w-100.fw-bold(type="submit")
                                i.bi.bi-stars.text-warning.me-1
                                | Higienizar
                else
                  .col-12
                    .alert.alert-secondary.text-center.mb-0.py-2
                      small Sin camas asignadas

  //Toast flotante de exito
  .position-fixed.bottom-0.end-0.p-3(style='z-index: 1055')
    .toast#limpiezaToast.border-0(role='alert', aria-live='assertive', aria-atomic='true')
      .toast-header.bg-success.text-white
        i.bi.bi-check-circle-fill.me-2
        strong.me-auto Cama Higienizada
        button.btn-close.btn-close-white(type='button', data-bs-dismiss='toast')
      .toast-body.bg-light
        | La cama se liberó correctamente y ya está disponible para nuevos ingresos.

block scripts
  script.
    document.addEventListener('DOMContentLoaded', function () {
      const isSuccess = #{success};
      if (isSuccess) {
        const toast = new bootstrap.Toast(document.getElementById('limpiezaToast'));
        toast.show();
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    });